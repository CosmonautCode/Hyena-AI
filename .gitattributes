# Git LFS for tracking large model files
# Initialize Git LFS
git lfs install
# Track model files with Git LFS
*.gguf filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text
# Git attributes for LFS
*.gguf linguist-generated
*.bin linguist-generated
*.safetensors linguist-generated
# Exclude model files from regular Git
# (they'll be tracked by LFS instead)
*.gguf binary
*.bin binary
*.safetensors binary
app/models/Hyena3-4B-Instruct-2507.Q2_K.gguf filter=lfs diff=lfs merge=lfs -text
