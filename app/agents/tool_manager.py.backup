from typing import Dict, List, Optional, Any
import subprocess
import os
import json
import time
from pathlib import Path
import difflib
import re


class ToolManager:
    """Enhanced tool manager for AI operations."""
    
    def __init__(self, workspace_manager, permission_system):
        self.workspace_manager = workspace_manager
        self.permission_system = permission_system
        # Initialize git and terminal managers if available
        try:
            from app.utils.git import GitManager
            self.git_manager = GitManager(workspace_manager)
        except ImportError:
            self.git_manager = None
        
        try:
            from app.utils.terminal import TerminalExecutor
            self.terminal_executor = TerminalExecutor()
        except ImportError:
            self.terminal_executor = None
        
    def get_all_tools(self) -> Dict[str, Dict]:
        """Get all available tools with their descriptions."""
        return {
            "read_file": {
                "func": self._read_file,
                "description": "Read the contents of a file",
                "parameters": {"filename": "string", "encoding": "string (optional)"}
            },
            "write_file": {
                "func": self._write_file,
                "description": "Write content to a file",
                "parameters": {"filename": "string", "content": "string", "encoding": "string (optional)"}
            },
            "list_files": {
                "func": self._list_files,
                "description": "List files in directory with pattern matching",
                "parameters": {"pattern": "string (optional, default: '*')", "recursive": "boolean (optional)"}
            },
            "run_command": {
                "func": self._run_command,
                "description": "Execute a shell command in the workspace",
                "parameters": {"command": "string", "cwd": "string (optional)"}
            },
            "git_status": {
                "func": self._git_status,
                "description": "Get git repository status",
                "parameters": {}
            },
            "git_diff": {
                "func": self._git_diff,
                "description": "Show git diff for changes",
                "parameters": {"file": "string (optional)", "staged": "boolean (optional)"}
            },
            "git_commit": {
                "func": self._git_commit,
                "description": "Create a git commit",
                "parameters": {"message": "string", "files": "list (optional)"}
            },
            "create_diff": {
                "func": self._create_diff,
                "description": "Create a diff between two file versions",
                "parameters": {"old_content": "string", "new_content": "string", "filename": "string"}
            },
            "search_files": {
                "func": self._search_files,
                "description": "Search for text patterns in files",
                "parameters": {"pattern": "string", "file_pattern": "string (optional)"}
            }
        }
    
    def _read_file(self, filename: str, encoding: str = "utf-8") -> Dict[str, Any]:
        """Read file contents with enhanced error handling."""
        try:
            result = self.workspace_manager.read_file(filename)
            if "error" in result:
                return {"success": False, "error": result["error"]}
            
            return {
                "success": True,
                "content": result["content"],
                "type": result.get("type", "text"),
                "size": len(result["content"]) if isinstance(result["content"], str) else 0
            }
        except Exception as e:
            return {"success": False, "error": str(e)}
    
    def _write_file(self, filename: str, content: str, encoding: str = "utf-8") -> Dict[str, Any]:
        """Write content to file with backup and diff generation."""
        try:
            # Create backup if file exists
            backup_path = None
            old_content = ""
            
            try:
                old_result = self.workspace_manager.read_file(filename)
                if "error" not in old_result:
                    old_content = old_result["content"]
                    backup_path = f"{filename}.backup.{int(time.time())}"
                    self.workspace_manager.write_file(backup_path, old_content)
            except:
                pass
            
            # Write new content
            result = self.workspace_manager.write_file(filename, content, "text")
            if "error" in result:
                return {"success": False, "error": result["error"]}
            
            # Generate diff
            diff = self._generate_text_diff(old_content, content, filename)
            
            return {
                "success": True,
                "message": result["message"],
                "backup_path": backup_path,
                "diff": diff,
                "size_change": len(content) - len(old_content)
            }
            
        except Exception as e:
            return {"success": False, "error": str(e)}
    
    def _list_files(self, pattern: str = "*", recursive: bool = False) -> Dict[str, Any]:
        """List files with enhanced filtering."""
        try:
            result = self.workspace_manager.list_files(pattern)
            if "error" in result:
                return {"success": False, "error": result["error"]}
            
            # Filter and categorize files
            files = []
            directories = []
            
            for item in result["files"]:
                if item["type"] == "directory":
                    directories.append(item)
                else:
                    files.append(item)
            
            return {
                "success": True,
                "files": files,
                "directories": directories,
                "total_count": len(files) + len(directories),
                "workspace_path": result["path"]
            }
            
        except Exception as e:
            return {"success": False, "error": str(e)}
    
    def _run_command(self, command: str, cwd: Optional[str] = None) -> Dict[str, Any]:
        """Execute shell command with enhanced output capture."""
        return self.terminal_executor.execute(command, cwd or self.workspace_manager.get_workspace())
    
    def _git_status(self) -> Dict[str, Any]:
        """Get git repository status."""
        return self.git_manager.get_status()
    
    def _git_diff(self, file: Optional[str] = None, staged: bool = False) -> Dict[str, Any]:
        """Get git diff."""
        return self.git_manager.get_diff(file, staged)
    
    def _git_commit(self, message: str, files: Optional[List[str]] = None) -> Dict[str, Any]:
        """Create git commit."""
        return self.git_manager.commit(message, files)
    
    def _create_diff(self, old_content: str, new_content: str, filename: str) -> Dict[str, Any]:
        """Create a diff between two content versions."""
        try:
            diff_lines = list(difflib.unified_diff(
                old_content.splitlines(keepends=True),
                new_content.splitlines(keepends=True),
                fromfile=f"a/{filename}",
                tofile=f"b/{filename}",
                lineterm=""
            ))
            
            diff_text = "".join(diff_lines)
            
            # Parse diff for statistics
            added_lines = sum(1 for line in diff_lines if line.startswith('+') and not line.startswith('+++'))
            removed_lines = sum(1 for line in diff_lines if line.startswith('-') and not line.startswith('---'))
            
            return {
                "success": True,
                "diff": diff_text,
                "stats": {
                    "added": added_lines,
                    "removed": removed_lines,
                    "changed": added_lines + removed_lines
                }
            }
            
        except Exception as e:
            return {"success": False, "error": str(e)}
    
    def _search_files(self, pattern: str, file_pattern: str = "*") -> Dict[str, Any]:
        """Search for text patterns in files."""
            
            # Get files to search
            list_result = self._list_files(file_pattern)
            if not list_result["success"]:
                return list_result
            
            matches = []
            regex = re.compile(pattern, re.IGNORECASE)
            
            for file_info in list_result["files"]:
                filename = file_info["name"]
                read_result = self._read_file(filename)
                
                if read_result["success"]:
                    content = read_result["content"]
                    lines = content.splitlines()
                    
                    file_matches = []
                    for line_num, line in enumerate(lines, 1):
                        if regex.search(line):
                            file_matches.append({
                                "line_number": line_num,
                                "line": line,
                                "context_start": max(0, line_num - 2),
                                "context_end": min(len(lines), line_num + 2)
                            })
                    
                    if file_matches:
                        matches.append({
                            "filename": filename,
                            "matches": file_matches,
                            "match_count": len(file_matches)
                        })
            
            return {
                "success": True,
                "matches": matches,
                "total_matches": sum(m["match_count"] for m in matches),
                "files_searched": len(list_result["files"])
            }
            
        except Exception as e:
            return {"success": False, "error": str(e)}
    
    def _generate_text_diff(self, old_content: str, new_content: str, filename: str) -> str:
        """Generate a unified diff."""
        diff_result = self._create_diff(old_content, new_content, filename)
        if diff_result["success"]:
            return diff_result["diff"]
        return ""


class GitManager:
    """Git operations manager."""
    
    def __init__(self, workspace_manager):
        self.workspace_manager = workspace_manager
    
    def get_status(self) -> Dict[str, Any]:
        """Get git repository status."""
        try:
            result = subprocess.run(
                ["git", "status", "--porcelain"],
                cwd=self.workspace_manager.get_workspace(),
                capture_output=True,
                text=True,
                timeout=30
            )
            
            if result.returncode != 0:
                return {"success": False, "error": "Not a git repository"}
            
            # Parse status output
            modified = []
            added = []
            untracked = []
            
            for line in result.stdout.strip().split('\n'):
                if line:
                    status = line[:2]
                    filename = line[3:]
                    
                    if status[0] in ['M', 'A'] or status[1] in ['M', 'A']:
                        modified.append(filename)
                    elif status[0] == '??':
                        untracked.append(filename)
                    elif status[0] == 'A':
                        added.append(filename)
            
            return {
                "success": True,
                "modified": modified,
                "added": added,
                "untracked": untracked,
                "is_clean": len(modified) + len(added) + len(untracked) == 0
            }
            
        except Exception as e:
            return {"success": False, "error": str(e)}
    
    def get_diff(self, file: Optional[str] = None, staged: bool = False) -> Dict[str, Any]:
        """Get git diff."""
        try:
            cmd = ["git", "diff"]
            if staged:
                cmd.append("--staged")
            if file:
                cmd.append(file)
            
            result = subprocess.run(
                cmd,
                cwd=self.workspace_manager.get_workspace(),
                capture_output=True,
                text=True,
                timeout=30
            )
            
            return {
                "success": True,
                "diff": result.stdout,
                "file": file
            }
            
        except Exception as e:
            return {"success": False, "error": str(e)}
    
    def commit(self, message: str, files: Optional[List[str]] = None) -> Dict[str, Any]:
        """Create a git commit."""
        try:
            # Stage files if specified
            if files:
                for file in files:
                    subprocess.run(
                        ["git", "add", file],
                        cwd=self.workspace_manager.get_workspace(),
                        capture_output=True,
                        timeout=30
                    )
            
            # Create commit
            result = subprocess.run(
                ["git", "commit", "-m", message],
                cwd=self.workspace_manager.get_workspace(),
                capture_output=True,
                text=True,
                timeout=30
            )
            
            return {
                "success": result.returncode == 0,
                "message": result.stdout if result.returncode == 0 else result.stderr
            }
            
        except Exception as e:
            return {"success": False, "error": str(e)}


class TerminalExecutor:
    """Terminal command executor."""
    
    def execute(self, command: str, cwd: Optional[str] = None) -> Dict[str, Any]:
        """Execute a terminal command."""
        try:
            result = subprocess.run(
                command,
                shell=True,
                cwd=cwd,
                capture_output=True,
                text=True,
                timeout=60
            )
            
            return {
                "success": result.returncode == 0,
                "stdout": result.stdout,
                "stderr": result.stderr,
                "return_code": result.returncode,
                "command": command,
                "cwd": cwd
            }
            
        except subprocess.TimeoutExpired:
            return {
                "success": False,
                "error": "Command timed out",
                "command": command
            }
        except Exception as e:
            return {
                "success": False,
                "error": str(e),
                "command": command
            }
